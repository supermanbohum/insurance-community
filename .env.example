# =========================================
# Supabase
# =========================================
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# service role key는 절대 클라이언트에 노출되지 않습니다. 서버(Route Handler/서버 액션)에서만 사용됩니다.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# =========================================
# 보안 (IP 해시용 서버 비밀키 - 외부에 노출 금지)
# =========================================
IP_HASH_SECRET=change-this-to-a-long-random-string

# =========================================
# 관리자
# =========================================
# 최초 super_admin 지정용 이메일(선택, README 참고)
ADMIN_BOOTSTRAP_EMAIL=admin@example.com

# =========================================
# 사이트 설정 (기본값 - site_settings 테이블로도 override 가능)
# =========================================
NEXT_PUBLIC_SITE_NAME=보험설계사 익명 커뮤니티
NEXT_PUBLIC_SITE_URL=https://example.com

# =========================================
# 환경 구분 / 개발용 데모 수치
# =========================================
# production | development | staging
NEXT_PUBLIC_APP_ENV=development
# true일 경우에만 개발/스테이징 환경에서 데모 표시 수치 사용 가능. production에서는 코드 레벨에서 강제로 무시됨.
ENABLE_DEMO_METRICS=false
